# templates (re-included below) should be uploaded.
*.mp4
*.mov
*.mkv
*.webm
*.avi
*.mp3
*.wav
*.m4a
*.aac
*.flac
*.ogg

# ...but KEEP the driving-template videos (any template_*.mp4, anywhere)
!template_*.mp4
